  "operations": {
    "getById": {
      "method": "GET",
      "url": "/v1/{ambiente}/{verticale?}/{Entita}/{id}",
      "description": "Recupera un oggetto per ID",
      "responseCodes": {
        "200": "Oggetto trovato",
        "404": "Oggetto non trovato"
      }
    },
    "search": {
      "method": "POST",
      "url": "/v1/{ambiente}/{verticale?}/{Entita}?_op=search",
      "description": "Ricerca libera tra gli oggetti",
      "requestBody": "SearchGroupDTO",
      "responseCodes": {
        "200": "Lista di oggetti trovati",
        "400": "Filtro di ricerca non specificato"
      }
    },
    "create": {
      "method": "POST",
      "url": "/v1/{ambiente}/{verticale?}/{Entita}",
      "description": "Crea un nuovo oggetto",
      "requestBody": "EntityDTO",
      "responseCodes": {
        "201": "Oggetto creato correttamente",
        "400": "Errore di validazione",
        "409": "Violazione logica di business"
      }
    },
    "update": {
      "method": "PUT",
      "url": "/v1/{ambiente}/{verticale?}/{Entita}/{id}",
      "description": "Aggiorna un oggetto esistente",
      "requestBody": "EntityDTO",
      "responseCodes": {
        "200": "Oggetto aggiornato",
        "400": "Errore di validazione",
        "404": "Oggetto non trovato",
        "409": "Violazione logica di business"
      }
    },
    "delete": {
      "method": "DELETE",
      "url": "/v1/{ambiente}/{verticale?}/{Entita}/{id}",
      "description": "Elimina un oggetto",
      "responseCodes": {
        "200": "Oggetto eliminato",
        "400": "Errore di validazione",
        "404": "Oggetto non trovato",
        "409": "Violazione logica di business"
      }
    },
    "validate": {
      "method": "POST",
      "url": "/v1/{ambiente}/{verticale?}/{Entita}?_op=validate",
      "description": "Valida un oggetto senza salvarlo",
      "requestBody": "EntityDTO",
      "responseCodes": {
        "200": "Oggetto valido",
        "400": "Oggetto non specificato",
        "409": "Oggetto non valido (contiene messaggi di validazione)"
      }
    },
    "validateProperties": {
      "method": "POST",
      "url": "/v1/{ambiente}/{verticale?}/{Entita}?_op=validateproperties",
      "description": "Valida una o più proprietà di un oggetto",
      "contentType": "application/x-www-form-urlencoded",
      "responseCodes": {
        "200": "Proprietà valide",
        "400": "Proprietà non specificate",
        "409": "Proprietà non valide"
      }
    }
  },

